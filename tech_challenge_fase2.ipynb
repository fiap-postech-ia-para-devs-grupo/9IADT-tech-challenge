    "experiments = [\n",
    "    {\"name\": \"Exp1_Pequeno\", \"pop_size\": 15, \"n_gen\": 10, \"p_mut\": 0.15},\n",
    "    {\"name\": \"Exp2_Medio\", \"pop_size\": 25, \"n_gen\": 15, \"p_mut\": 0.20},\n",
